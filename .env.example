MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/skillcourse
PORT=5000
JWT_SECRET=your_super_secret_key_change_this

# Supabase — avatars and course images
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_secret_key>

# Razorpay
RAZORPAY_KEY_ID=rzp_test_<key_id>
RAZORPAY_KEY_SECRET=<key_secret>
RAZORPAY_WEBHOOK_SECRET=<webhook_secret>

# Bunny Stream — course video hosting
# Stream API key: Bunny dashboard > Stream > Library > API
BUNNY_STREAM_API_KEY=
# Library ID: Bunny dashboard > Stream > Library (numeric id in URL)
BUNNY_LIBRARY_ID=
# CDN hostname: Bunny dashboard > Stream > Library > CDN Hostname e.g. vz-xxxxxxxx.b-cdn.net
BUNNY_CDN_HOSTNAME=
